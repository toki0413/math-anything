{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GROMACS topology",
  "scopeName": "source.gromacs",
  "fileTypes": ["top", "itp"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#section" },
    { "include": "#number" },
    { "include": "#atom" }
  ],
  "repository": {
    "comment": {
      "patterns": [{
        "name": "comment.line.gromacs",
        "match": ";.*$"
      }]
    },
    "section": {
      "patterns": [{
        "name": "entity.name.function.gromacs",
        "match": "^\\s*\\[[^\\]]+\\]"
      }]
    },
    "number": {
      "patterns": [{
        "name": "constant.numeric.gromacs",
        "match": "[-+]?[0-9]*\\.?[0-9]+([eE][-+]?[0-9]+)?"
      }]
    },
    "atom": {
      "patterns": [{
        "name": "entity.name.tag.gromacs",
        "match": "\\b(H|He|Li|Be|B|C|N|O|F|Ne|Na|Mg|Al|Si|P|S|Cl|Ar|K|Ca|Sc|Ti|V|Cr|Mn|Fe|Co|Ni|Cu|Zn|Ga|Ge|As|Se|Br|Kr|Rb|Sr|Y|Zr|Nb|Mo|Tc|Ru|Rh|Pd|Ag|Cd|In|Sn|Sb|Te|I|Xe|Cs|Ba|La|Hf|Ta|W|Re|Os|Ir|Pt|Au|Hg|Tl|Pb|Bi)\\b"
      }]
    }
  }
}
