{
  "name": "bourbaki-vscode",
  "displayName": "Bourbaki",
  "description": "Mathematical structure analysis for scientific computing input files",
  "version": "0.1.0",
  "publisher": "math-anything",
  "repository": {
    "type": "git",
    "url": "https://github.com/toki0413/math-anything"
  },
  "bugs": {
    "url": "https://github.com/toki0413/math-anything/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Visualization"
  ],
  "keywords": [
    "vasp",
    "lammps",
    "quantum-espresso",
    "abaqus",
    "openfoam",
    "gromacs",
    "dft",
    "md",
    "cfd",
    "fem",
    "mathematical-structures"
  ],
  "activationEvents": [
    "onLanguage:vasp-incar",
    "onLanguage:vasp-poscar",
    "onLanguage:qe-in",
    "onLanguage:lammps-input",
    "onLanguage:abaqus-input",
    "onLanguage:openfoam",
    "onLanguage:gromacs-top",
    "onCommand:bourbaki.analyzeFile",
    "onCommand:bourbaki.analyzeWorkspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Bourbaki",
      "properties": {
        "bourbaki.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python interpreter that has `bourbaki` installed."
        },
        "bourbaki.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Bourbaki language server."
        },
        "bourbaki.lsp.trace": {
          "type": "boolean",
          "default": false,
          "description": "Trace LSP communication to the output channel."
        }
      }
    },
    "commands": [
      {
        "command": "bourbaki.analyzeFile",
        "title": "Analyze Mathematical Structure",
        "category": "Bourbaki"
      },
      {
        "command": "bourbaki.analyzeWorkspace",
        "title": "Analyze Workspace",
        "category": "Bourbaki"
      },
      {
        "command": "bourbaki.verifyEquation",
        "title": "Verify Selected Equation",
        "category": "Bourbaki"
      },
      {
        "command": "bourbaki.solveNumerical",
        "title": "Solve Numerical Problem",
        "category": "Bourbaki"
      },
      {
        "command": "bourbaki.openWebview",
        "title": "Open Analysis Dashboard",
        "category": "Bourbaki"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "bourbaki.analyzeFile",
          "group": "9_cutcopypaste@5"
        },
        {
          "command": "bourbaki.verifyEquation",
          "when": "editorHasSelection",
          "group": "9_cutcopypaste@6"
        }
      ],
      "explorer/context": [
        {
          "command": "bourbaki.analyzeFile",
          "group": "2_workspace@5"
        }
      ]
    },
    "languages": [
      {
        "id": "vasp-incar",
        "aliases": [
          "VASP INCAR",
          "incar"
        ],
        "extensions": [
          ".incar"
        ],
        "filenames": [
          "INCAR"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "vasp-poscar",
        "aliases": [
          "VASP POSCAR",
          "poscar"
        ],
        "extensions": [
          ".poscar"
        ],
        "filenames": [
          "POSCAR"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "qe-in",
        "aliases": [
          "Quantum ESPRESSO input",
          "qe-in"
        ],
        "extensions": [
          ".in"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "lammps-input",
        "aliases": [
          "LAMMPS input",
          "lammps"
        ],
        "extensions": [
          ".lmp"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "abaqus-input",
        "aliases": [
          "Abaqus input",
          "abaqus"
        ],
        "extensions": [
          ".inp"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "openfoam",
        "aliases": [
          "OpenFOAM"
        ],
        "filenames": [
          "controlDict",
          "fvSchemes",
          "fvSolution",
          "transportProperties"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "gromacs-top",
        "aliases": [
          "GROMACS topology",
          "top"
        ],
        "extensions": [
          ".top",
          ".itp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vasp-incar",
        "scopeName": "source.vasp.incar",
        "path": "./syntaxes/vasp-incar.tmLanguage.json"
      },
      {
        "language": "vasp-poscar",
        "scopeName": "source.vasp.poscar",
        "path": "./syntaxes/vasp-poscar.tmLanguage.json"
      },
      {
        "language": "qe-in",
        "scopeName": "source.qe.in",
        "path": "./syntaxes/qe-in.tmLanguage.json"
      },
      {
        "language": "lammps-input",
        "scopeName": "source.lammps",
        "path": "./syntaxes/lammps.tmLanguage.json"
      },
      {
        "language": "abaqus-input",
        "scopeName": "source.abaqus",
        "path": "./syntaxes/abaqus.tmLanguage.json"
      },
      {
        "language": "openfoam",
        "scopeName": "source.openfoam",
        "path": "./syntaxes/openfoam.tmLanguage.json"
      },
      {
        "language": "gromacs-top",
        "scopeName": "source.gromacs",
        "path": "./syntaxes/gromacs.tmLanguage.json"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "bourbaki.domains",
          "name": "Bourbaki Domains",
          "when": "bourbaki:enabled"
        },
        {
          "id": "bourbaki.analysis",
          "name": "Bourbaki Analysis",
          "when": "bourbaki:enabled"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bourbaki",
          "title": "Bourbaki",
          "icon": "$(symbol-math)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
